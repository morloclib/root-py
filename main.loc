       , PartialInto I32 U32
       , PartialInto I64 U32
       , PartialInto F32 U32
       , PartialInto F64 U32
       , PartialInto Real U32
       , PartialInto Int U32 where
  %inline source Py from "core.py" ("morloc_try_u32" as tryInto)

instance PartialInto I8 U64
       , PartialInto I16 U64
       , PartialInto I32 U64
       , PartialInto I64 U64
       , PartialInto F32 U64
       , PartialInto F64 U64
       , PartialInto Real U64
       , PartialInto Int U64 where
  %inline source Py from "core.py" ("morloc_try_u64" as tryInto)

instance PartialInto U8 I8
       , PartialInto U16 I8
       , PartialInto U32 I8
       , PartialInto U64 I8
       , PartialInto I16 I8
       , PartialInto I32 I8
       , PartialInto I64 I8
       , PartialInto F32 I8
       , PartialInto F64 I8
       , PartialInto Real I8
       , PartialInto Int I8 where
  %inline source Py from "core.py" ("morloc_try_i8" as tryInto)

instance PartialInto U16 I16
       , PartialInto U32 I16
       , PartialInto U64 I16
       , PartialInto I32 I16
       , PartialInto I64 I16
       , PartialInto F32 I16
       , PartialInto F64 I16
       , PartialInto Real I16
       , PartialInto Int I16 where
  %inline source Py from "core.py" ("morloc_try_i16" as tryInto)

instance PartialInto U32 I32
       , PartialInto U64 I32
       , PartialInto I64 I32
       , PartialInto F32 I32
       , PartialInto F64 I32
       , PartialInto Real I32
       , PartialInto Int I32 where
  %inline source Py from "core.py" ("morloc_try_i32" as tryInto)

instance PartialInto U64 I64
       , PartialInto F32 I64
       , PartialInto F64 I64
       , PartialInto Real I64
       , PartialInto Int I64 where
  %inline source Py from "core.py" ("morloc_try_i64" as tryInto)

instance PartialInto U32 Int
       , PartialInto U64 Int
       , PartialInto I64 Int
       , PartialInto F32 Int
